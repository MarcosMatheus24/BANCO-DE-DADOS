create table Consultas(
CPF_Pacientes varchar(14) unique unique not null,
foreign key (CPF_Pacientes) references Pacientes(CPF),
Data_consultas date,
Diagnosticos varchar(254),
CRM_Medico int auto_increment unique not null,
foreign key (CRM_Medico) references Medicos(CRM) 
);
